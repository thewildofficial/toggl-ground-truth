{
  "manifest_version": 3,
  "name": "Ground Truth Daemon",
  "version": "0.1.0",
  "description": "Intelligent screen time tracker for Ground Truth Goals. Classifies your browsing behavior and logs it.",
  "browser_specific_settings": {
    "gecko": {
      "id": "ground-truth-daemon@toggl-goals",
      "strict_min_version": "115.0"
    }
  },
  "permissions": [
    "tabs",
    "storage",
    "alarms",
    "activeTab"
  ],
  "host_permissions": [
    "http://localhost/*",
    "http://localhost:5000/*",
    "https://*.youtube.com/*",
    "https://*.x.com/*",
    "https://*.twitter.com/*",
    "https://*.instagram.com/*",
    "https://*.tiktok.com/*",
    "https://*.reddit.com/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "options_ui": {
    "page": "options.html",
    "browser_style": true
  },
  "action": {
    "default_title": "Ground Truth Daemon",
    "default_popup": "popup.html"
  }
}